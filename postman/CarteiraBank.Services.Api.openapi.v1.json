  "components": {
    "schemas": {
      "CriarAcordoRequisicao": {
        "required": [
          "valorDesconto",
          "quantidadeParcelas"
        ],
        "type": "object",
        "properties": {
          "valorDesconto": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "quantidadeParcelas": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "CriarSolicitacaoCreditoRequisicao": {
        "required": [
          "valorSolicitado",
          "quantidadeParcelasSolicitada",
          "finalidade"
        ],
        "type": "object",
        "properties": {
          "valorSolicitado": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "quantidadeParcelasSolicitada": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "finalidade": {
            "type": "string"
          }
        }
      },
      "DecidirSolicitacaoCreditoRequisicao": {
        "required": [
          "aprovar",
          "motivo"
        ],
        "type": "object",
        "properties": {
          "aprovar": {
            "type": "boolean"
          },
          "motivo": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
