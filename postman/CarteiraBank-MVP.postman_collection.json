    {
      "name": "10 - Supervisor - Emitir Boleto (informe parcelaAcordoId)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-User-Id",
            "value": "{{supervisorUserId}}",
            "type": "text"
          },
          {
            "key": "X-User-Role",
            "value": "Supervisor",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/acordos/{{parcelaAcordoId}}/boleto",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "acordos",
            "{{parcelaAcordoId}}",
            "boleto"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (!pm.environment.get(\"parcelaAcordoId\")) {",
              "  pm.test(\"parcelaAcordoId pendente\", function () {",
              "    pm.expect(true).to.eql(true);",
              "  });",
              "} else {",
              "  pm.test(\"Status 200\", function () {",
              "    pm.response.to.have.status(200);",
              "  });",
              "  var boleto = pm.response.json();",
              "  if (boleto && boleto.id) {",
              "    pm.environment.set(\"boletoId\", boleto.id);",
              "  }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
