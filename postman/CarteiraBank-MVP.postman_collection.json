          },
          {
            "key": "X-User-Role",
            "value": "Cliente",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/clientes/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "clientes",
            "me"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Cliente - Criar Solicitacao (Valida)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "X-User-Id",
            "value": "{{clienteUserId}}",
            "type": "text"
          },
          {
            "key": "X-User-Role",
            "value": "Cliente",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"valorSolicitado\": 2500,\n  \"quantidadeParcelasSolicitada\": 6,\n  \"finalidade\": \"Renegociacao\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/solicitacoes-credito",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "solicitacoes-credito"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var data = pm.response.json();",
              "if (data && data.id) {",
              "  pm.environment.set(\"solicitacaoId\", data.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "04 - Cliente - Criar Solicitacao (Invalida - 400)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "X-User-Id",
            "value": "{{clienteUserId}}",
            "type": "text"
          },
          {
            "key": "X-User-Role",
            "value": "Cliente",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"valorSolicitado\": 0,\n  \"quantidadeParcelasSolicitada\": 0,\n  \"finalidade\": \"Teste\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/solicitacoes-credito",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "solicitacoes-credito"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 400\", function () {",
              "  pm.response.to.have.status(400);",
              "});",
              "var erro = pm.response.json();",
              "pm.test(\"Contrato de erro\", function () {",
              "  pm.expect(erro).to.have.property(\"codigo\");",
              "  pm.expect(erro).to.have.property(\"mensagem\");",
              "  pm.expect(erro).to.have.property(\"orientacao\");",
              "  pm.expect(erro).to.have.property(\"traceId\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
