    {
      "name": "07 - Cliente - Listar Contratos",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-User-Id",
            "value": "{{clienteUserId}}",
            "type": "text"
          },
          {
            "key": "X-User-Role",
            "value": "Cliente",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/contratos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "contratos"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var lista = pm.response.json();",
              "if (Array.isArray(lista) && lista.length > 0) {",
              "  pm.environment.set(\"contratoId\", lista[0].id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
